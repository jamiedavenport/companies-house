{
  "name": "@jxdltd/companies-house",
  "version": "0.2.1",
  "description": "A modern, fully typed TypeScript SDK for the Companies House Public Data API",
  "keywords": [
    "api",
    "companies house",
    "companies-house",
    "company",
    "sdk",
    "typescript",
    "uk"
  ],
  "homepage": "https://github.com/jamiedavenport/companies-house/tree/main/packages/sdk#readme",
  "bugs": {
    "url": "https://github.com/jamiedavenport/companies-house/issues"
  },
  "license": "MIT",
  "author": "Jamie Davenport",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jamiedavenport/companies-house.git",
    "directory": "packages/sdk"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./openapi.json": "./dist/openapi.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack && cp ../spec/spec/companies-house.json dist/openapi.json",
    "generate": "openapi-ts",
    "test": "vp test run"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.84.4",
    "@jxdltd/companies-house-spec": "workspace:*",
    "@jxdltd/companies-house-tooling": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
